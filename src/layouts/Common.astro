---
const title = Astro.props.title ? Astro.props.title + " - " : "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title + "Knowledge Base · Mycostech"}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles: link your blog-template CSS here -->
    <!-- <link rel="stylesheet" href="/styles/global.css" /> -->
    <link rel="stylesheet" href="/code.css" />
    <slot name="head-style" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">Knowledge Base</a>
        <nav class="site-nav">
          <a href="/about">About</a>
          <a href="/browse">Articles</a>
          <a href="/category">Topics</a>
          <a href="/contribute" class="nav-cta">Contribute</a>
        </nav>
      </div>
    </header>
    
    <slot />

    {
      !Astro.props.nofooter &&
      <footer class="site-footer">
        <div class="footer-inner">
          <div class="footer-brand">
            <a href="/" class="site-logo"
              >Knowledge <span style="color:var(--accent)">Base</span></a
            >
            <p>
              Explainer, Gotchas, Article, Showcase, etc. in <code>.md</code>
            </p>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} Mycostech Knowledge Base.</span>
          <span
            >Built with <a href="https://astro.build">Astro</a> + <a
              href="https://sveltia.com">Sveltia CMS</a
            ></span
          >
        </div>
      </footer>
    }
    
  </body>
</html>
